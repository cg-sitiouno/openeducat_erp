<odoo>
  <data>
    <record id="view_op_certificate_template_list" model="ir.ui.view">
      <field name="name">op.certificate.template.list</field>
      <field name="model">op.certificate.template</field>
      <field name="arch" type="xml">
        <list string="Plantillas de Certificado">
          <field name="name"/>
          <field name="course_id"/>
          <field name="hours"/>
        </list>
      </field>
    </record>
    <record id="view_op_certificate_template_form" model="ir.ui.view">
      <field name="name">op.certificate.template.form</field>
      <field name="model">op.certificate.template</field>
      <field name="arch" type="xml">
        <form string="Plantilla de Certificado">
          <sheet>
            <group>
              <field name="name"/>
              <field name="course_id"/>
              <field name="hours"/>
            </group>
            <group>
              <field name="background_image"/>
            </group>
            <group string="Firma">
              <field name="signer_name"/>
              <field name="signer_role"/>
              <field name="signer_signature"/>
            </group>
          </sheet>
        </form>
      </field>
    </record>
    <record id="action_op_certificate_template" model="ir.actions.act_window">
      <field name="name">Plantillas</field>
      <field name="res_model">op.certificate.template</field>
      <field name="view_mode">list,form</field>
    </record>
  </data>
</odoo>
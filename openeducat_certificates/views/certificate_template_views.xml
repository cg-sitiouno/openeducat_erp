<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>

    <!-- Lista (en Odoo 18 es <list>, no <tree>) -->
    <record id="view_op_certificate_template_list" model="ir.ui.view">
      <field name="name">op.certificate.template.list</field>
      <field name="model">op.certificate.template</field>
      <field name="arch" type="xml">
        <list string="Plantillas de Certificados" delete="true">
          <field name="name"/>
          <field name="course_id"/>
          <field name="hours"/>
        </list>
      </field>
    </record>

    <!-- Formulario -->
    <record id="view_op_certificate_template_form" model="ir.ui.view">
      <field name="name">op.certificate.template.form</field>
      <field name="model">op.certificate.template</field>
      <field name="arch" type="xml">
      <form string="Plantilla de Certificado" delete="true">
          <header>
            <button name="unlink" type="object" 
                    string="Eliminar" class="btn-danger"
                    confirm="¿Está seguro de que desea eliminar esta plantilla?"/>
          </header>
          <sheet>
            <group>
              <group>
                <field name="name"/>
                <field name="course_id"/>
                <field name="hours"/>
              </group>
              <group>
                <!-- Campo imagen con previsualización -->
                <field name="bg_image" widget="image"
                       options="{'preview_image': 'bg_image'}"/>
                <!-- La etiqueta debe referenciar el campo con 'for' -->
                <label for="bg_image"
                       string="Sube la imagen de fondo del certificado (PNG/JPG)"/>
              </group>
            </group>
          </sheet>
        </form>
      </field>
    </record>

    <!-- Acción para el menú -->
    <record id="action_op_certificate_template" model="ir.actions.act_window">
      <field name="name">Plantillas de Certificados</field>
      <field name="res_model">op.certificate.template</field>
      <field name="view_mode">list,form</field>
      <field name="help" type="html">
        <p class="o_view_nocontent_smiling_face">
          Crea y administra las plantillas base para certificados de participación.
        </p>
      </field>
    </record>

  </data>
</odoo>

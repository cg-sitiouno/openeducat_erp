<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>

<template id="verify_form" name="Verificar Certificado">
  <t t-call="website.layout">
    <t t-set="title">Verificar certificado</t>
    <div class="container py-5">
      <h2>Verificar certificado</h2>
      <form action="/certificates/verify/result" method="post" class="mt-3">
        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
        <div class="form-group">
          <label>Cédula</label>
          <input class="form-control" type="text" name="national_id" required="required"/>
        </div>
        <button class="btn btn-primary mt-3" type="submit">Buscar</button>
      </form>
    </div>
  </t>
</template>



    <template id="verify_ok" name="Certificado encontrado">
      <t t-call="website.layout">
        <div class="container py-5">
          <h3>Certificado válido</h3>
          <p><b>Estudiante:</b> <t t-esc="cert.student_id.name"/></p>
          <p><b>Cédula:</b> <t t-esc="cert.national_id"/></p>
          <p><b>Curso:</b> <t t-esc="cert.course_id.name"/></p>
          <p><b>Horas:</b> <t t-esc="cert.hours"/></p>
          <p><b>Fecha de emisión:</b> <t t-esc="cert.issue_date"/></p>
          <a class="btn btn-secondary mt-3"
             t-att-href="'/report/pdf/openeducat_certificates.action_certificate/%s' % cert.id">
            Descargar PDF
          </a>
        </div>
      </t>
    </template>

    <template id="verify_fail" name="No encontrado">
      <t t-call="website.layout">
        <div class="container py-5">
          <h3>No se encontró un certificado emitido con esa cédula.</h3>
        </div>
      </t>
    </template>

  </data>
</odoo>
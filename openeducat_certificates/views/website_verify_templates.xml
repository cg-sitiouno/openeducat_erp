<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>

    <!-- FORMULARIO DE BÚSQUEDA -->
    <template id="verify_form" name="Verificar Certificado">
      <t t-call="website.layout">
        <t t-set="title">Verificar certificado</t>
        <div class="container py-5">
          <h2>Verificar certificado</h2>
          <form action="/certificates/verify/result" method="post" class="mt-3">
            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
            <div class="form-group">
              <label>Cédula</label>
              <input class="form-control" type="text" name="national_id" required="required"/>
            </div>
            <button class="btn btn-primary mt-3" type="submit">Buscar</button>
          </form>
        </div>
      </t>
    </template>

    <!-- RESULTADO EXITOSO -->
    <template id="verify_ok" name="Certificado encontrado">
      <t t-call="website.layout">
        <t t-set="title">Certificado válido</t>

        <style>
          /* Marco que usa el tamaño NATURAL de la imagen */
          .cert-frame {
            display: inline-block;           /* ancho = ancho de la imagen */
            position: relative;              /* para posicionar overlays */
            line-height: 0;                  /* elimina gaps bajo la imagen */
            border-radius: 16px;
            box-shadow: 0 10px 30px rgba(0,0,0,.12);
            overflow: hidden;
          }
          .cert-bg {
            display: block;
            height: auto;
            max-width: 100%;
          }
          /* Capa de texto superpuesta */
          .cert-layer {
            position: absolute;
            left: 50%;
            transform: translateX(-50%);
            width: 82%;
            text-align: center;
            color: #000;
            line-height: 1.35;
          }
          /* Aproxima las posiciones (porcentaje vertical) a tu diseño */
          .ov-name  { top: 45%; font-style: italic; font-weight: 700;
                      font-size: clamp(36px, 4.8vw, 52px); color:#0b3042}
          .ov-id    { top: 55%; font-size: clamp(32px, 1.6vw, 16px); color:#0b3042 }
          .ov-desc  { top: 62%; font-size: clamp(12px, 1.7vw, 18px); color:#0b3042 }

          .cert-actions { margin: 16px 0 32px; }
          @media print {
            header, footer, .o_main_navbar, .cert-actions { display:none !important; }
            body { -webkit-print-color-adjust: exact; print-color-adjust: exact; }
            .cert-frame { box-shadow: none; }
          }
        </style>

        <div class="container py-4 text-center">
          <div class="cert-frame">
            <!-- Fondo desde la plantilla, servido por nuestro controlador público -->
            <img class="cert-bg"
                 t-att-src="'/certificates/template_bg/%s' % cert.template_id.id"
                 alt="Certificado"/>

            <!-- Nombre centrado en cursiva -->
            <div class="cert-layer ov-name">
              <t t-esc="cert.student_id.name"/>
            </div>

            <!-- Cédula -->
            <div class="cert-layer ov-id">
              Cédula de identidad: <t t-esc="cert.national_id"/>
            </div>

            <!-- Descripción: curso (de la plantilla) + fecha (del certificado) + horas (de la plantilla) -->
            <div class="cert-layer ov-desc">
              Por haber asistido a
              <t t-esc="cert.template_id.course_id and cert.template_id.course_id.name or ''"/>,
              realizado el
              <span t-field="cert.issue_date" t-options="{'widget': 'date'}"/>,
              con una duración de
              <t t-esc="cert.template_id.hours or 0.0"/> horas académicas.
            </div>
          </div>

          <!-- Botón PDF lo dejamos comentado por ahora
          <div class="cert-actions text-start">
            <a class="btn btn-dark" t-att-href="'/certificates/print/%s-%s' % (slug(cert), cert.id)">
              Descargar PDF
            </a>
          </div>
          -->
        </div>
      </t>
    </template>

    <!-- RESULTADO FALLIDO -->
    <template id="verify_fail" name="No encontrado">
      <t t-call="website.layout">
        <div class="container py-5">
          <div class="alert alert-warning shadow-sm">
            <strong>No se encontró un certificado emitido con esa cédula.</strong>
          </div>
        </div>
      </t>
    </template>

  </data>
</odoo>
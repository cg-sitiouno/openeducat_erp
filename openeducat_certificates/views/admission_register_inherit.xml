<odoo>
  <data>
    <record id="view_op_admission_register_form_inherit_cert" model="ir.ui.view">
      <field name="name">op.admission.register.form.inherit.cert</field>
      <field name="model">op.admission.register</field>
      <!-- Ajusta este inherit_id si tu xml_id difiere -->
      <field name="inherit_id" ref="openeducat_admission.view_op_admission_register_form"/>
      <field name="arch" type="xml">
        <xpath expr="//sheet//group[1]" position="inside">
          <field name="certificate_template_id"/>
        </xpath>
        <xpath expr="//header" position="inside">
          <button name="action_issue_certificates" type="object"
                  string="Emitir certificados" class="btn-primary"/>
        </xpath>
      </field>
    </record>
  </data>
</odoo>

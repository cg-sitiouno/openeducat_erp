<?xml version="1.0" encoding="UTF-8"?>
<odoo>
  <!-- Acción de reporte solo HTML (evita wkhtmltopdf).
       El endpoint /report/html/... funciona y permite imprimir/guardar PDF desde el navegador. -->
  <record id="report_certificate_document_action" model="ir.actions.report">
    <field name="name">Certificado</field>
    <field name="model">op.certificate</field>
    <field name="report_name">openeducat_certificates.report_certificate_document</field>
    <field name="report_type">qweb-html</field>
    <field name="report_file">openeducat_certificates.report_certificate_document</field>
    <field name="print_report_name">'Certificado - %s' % (object.partner_id and object.partner_id.name or object.id)</field>
  </record>
</odoo>

<?xml version="1.0" encoding="UTF-8"?>
<odoo>
  <template id="report_certificate_document">
    <t t-call="web.html_container">
      <t t-foreach="docs" t-as="doc">

        <div class="cert-page">

          <!-- Fondo solo si hay template y tiene imagen o URL -->
          <t t-if="doc.template_id and (doc.template_id.background_image or doc.template_id.background_url)">
            <t t-set="bg_src"
               t-value="doc.template_id.background_image
                        and ('/web/image/%s/%s/background_image' % (doc.template_id._name, doc.template_id.id))
                        or doc.template_id.background_url"/>
            <img class="cert-bg" t-att-src="bg_src"/>
          </t>

          <div class="cert-content">
            <h1 class="tit">CERTIFICADO</h1>
            <h2 class="sub">DE PARTICIPACIÓN</h2>

            <div class="nombre" t-esc="(doc.partner_id and doc.partner_id.name) or ''"/>
            <div class="dni">
              Cédula de identidad: <span t-esc="doc.national_id or ''"/>
            </div>

            <div class="detalle">
              <t t-if="doc.course_id">
                Por haber asistido a <strong t-esc="doc.course_id.name or ''"/>.
              </t>
              <t t-if="doc.issue_date">
                &#160;Fecha: <span t-esc="doc.issue_date"/>
              </t>
              <t t-if="doc.duration">
                &#160;Duración: <span t-esc="doc.duration"/> horas.
              </t>
            </div>

            <!-- Código QR de verificación (esquina inferior derecha) -->
            <div class="qr-corner" t-if="doc.qr_code_url">
              <img t-att-src="doc.qr_code_url" alt="QR" class="qr-img"/>
              <div class="qr-label">Verificar autenticidad</div>
            </div>
          </div>
        </div>

        <style>
          .cert-page{
            position: relative; width: 100%; min-height: 700px; overflow: hidden;
            font-family: 'Montserrat', Arial, sans-serif;
          }
          .cert-bg{
            position:absolute; inset:0; width:100%; height:100%; object-fit:cover; z-index:0;
          }
          .cert-content{
            position:relative; z-index:1; text-align:center; padding:60px 50px 40px 50px; color:#123;
          }
          .tit{ font-size:42px; letter-spacing:2px; margin:10px 0 0 0; }
          .sub{ font-size:20px; color:#1a5899; margin:0 0 30px 0; letter-spacing:3px; }
          .nombre{ font-size:34px; font-weight:700; margin:30px 0 10px 0; }
          .dni, .detalle{ font-size:14px; margin:8px 0; }
          .qr-corner{
            position:absolute; bottom:20px; right:20px; text-align:center; z-index:2;
          }
          .qr-img{
            width:120px; height:120px; display:block; margin:0 auto 5px;
          }
          .qr-label{
            font-size:9px; color:#666; margin:0;
          }
        </style>

        <p style="page-break-after: always;"></p>
      </t>
    </t>
  </template>
</odoo>

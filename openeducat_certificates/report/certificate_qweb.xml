<?xml version="1.0" encoding="UTF-8"?>
<odoo>
  <template id="report_certificate_document">
    <t t-foreach="docs" t-as="doc">

        <div class="cert-page">
          <div class="cert-frame">
            <!-- Fondo desde la plantilla -->
            <img class="cert-bg"
                 t-att-src="'/certificates/template_bg/%s' % doc.template_id.id"
                 alt="Certificado"/>

            <!-- Nombre centrado en cursiva -->
            <div class="cert-layer ov-name">
              <t t-esc="doc.student_id.name"/>
            </div>

            <!-- Cédula -->
            <div class="cert-layer ov-id">
              Cédula de identidad: <t t-esc="doc.national_id"/>
            </div>

            <!-- Descripción: curso + fecha + horas -->
            <div class="cert-layer ov-desc">
              Por haber asistido a
              <t t-esc="doc.template_id.course_id and doc.template_id.course_id.name or ''"/>,
              realizado el
              <span t-field="doc.issue_date" t-options="{'widget': 'date'}"/>,
              con una duración de
              <t t-esc="doc.template_id.hours or 0.0"/> horas académicas.
            </div>

            <!-- Código QR de verificación (esquina inferior derecha) -->
            <div class="qr-corner-print" t-if="doc.qr_code_url">
              <img t-att-src="doc.qr_code_url" alt="QR" class="qr-img-print"/>
              <div class="qr-label-print">Verificar autenticidad</div>
            </div>
          </div>
        </div>

        <style>
          html, body {
            margin: 0 !important;
            padding: 0 !important;
            width: 100%;
            height: 100%;
            overflow: hidden;
          }
          @page {
            size: A4 landscape;
            margin: 0;
          }
          * {
            box-sizing: border-box;
          }
          .cert-page {
            width: 297mm;
            height: 210mm;
            display: flex;
            align-items: center;
            justify-content: center;
            background: white;
            page-break-after: always;
            margin: 0;
            padding: 0;
            overflow: hidden;
          }
          /* Marco que contiene la imagen */
          .cert-frame {
            position: relative;
            width: 100%;
            height: 100%;
          }
          .cert-bg {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            object-fit: cover;
            object-position: center;
          }
          /* Capa de texto superpuesta */
          .cert-layer {
            position: absolute;
            left: 50%;
            transform: translateX(-50%);
            width: 85%;
            text-align: center;
            color: #0b3042;
            line-height: 1.2;
            font-family: 'Montserrat', Arial, sans-serif;
          }
          /* Posiciones y tamaños en mm para A4 landscape */
          .ov-name  { 
            top: 44%; 
            font-style: italic; 
            font-weight: 700;
            font-size: 12mm;
          }
          .ov-id    { 
            top: 54%; 
            font-size: 4.5mm;
          }
          .ov-desc  { 
            top: 61%; 
            font-size: 4mm;
            line-height: 1.3;
          }
          /* QR en esquina inferior derecha */
          .qr-corner-print {
            position: absolute;
            bottom: 5mm;
            right: 5mm;
            text-align: center;
            z-index: 2;
          }
          .qr-img-print {
            width: 25mm;
            height: 25mm;
            display: block;
            margin: 0 auto 2mm;
          }
          .qr-label-print {
            font-size: 2mm;
            color: #666;
            margin: 0;
          }
        </style>

        <script>
          // Auto-abrir diálogo de impresión si viene el parámetro print=1
          if (window.location.search.includes('print=1')) {
            window.onload = function() {
              // Esperar a que la imagen de fondo se cargue completamente
              var bgImage = document.querySelector('.cert-bg');
              if (bgImage) {
                if (bgImage.complete) {
                  // La imagen ya está cargada
                  setTimeout(function() {
                    window.print();
                  }, 500);
                } else {
                  // Esperar a que la imagen termine de cargar
                  bgImage.onload = function() {
                    setTimeout(function() {
                      window.print();
                    }, 500);
                  };
                  // Timeout de seguridad: imprimir después de 5 segundos aunque no cargue
                  setTimeout(function() {
                    window.print();
                  }, 5000);
                }
              } else {
                // No hay imagen, imprimir directamente
                setTimeout(function() {
                  window.print();
                }, 500);
              }
            };
          }
        </script>

      </t>
  </template>
</odoo>
